<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <p class="footer-brand">{{ site.name }}</p>
        <p>{{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}</p>
        <div class="social-links">
          <a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook" data-analytics="social_click" data-analytics-network="facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.3-1.5 1.6-1.5h1.6V3.6c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.3H7.6V13h2.7v8h3.2z"/></svg>
          </a>
          <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram" data-analytics="social_click" data-analytics-network="instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4.3c2.5 0 2.8 0 3.8.1 2.5.1 3.7 1.3 3.8 3.8 0 1 .1 1.3.1 3.8s0 2.8-.1 3.8c-.1 2.5-1.3 3.7-3.8 3.8-1 .1-1.3.1-3.8.1s-2.8 0-3.8-.1c-2.5-.1-3.7-1.3-3.8-3.8 0-1-.1-1.3-.1-3.8s0-2.8.1-3.8c.1-2.5 1.3-3.7 3.8-3.8 1-.1 1.3-.1 3.8-.1zM12 2.4c-2.6 0-2.9 0-3.9.1-3.4.2-5.3 2-5.5 5.5 0 1-.1 1.4-.1 4s0 2.9.1 3.9c.2 3.4 2 5.3 5.5 5.5 1 0 1.3.1 3.9.1s2.9 0 3.9-.1c3.4-.2 5.3-2 5.5-5.5 0-1 .1-1.3.1-3.9s0-2.9-.1-3.9c-.2-3.4-2-5.3-5.5-5.5-1-.1-1.3-.1-3.9-.1zm0 4.7a4.9 4.9 0 1 0 0 9.8 4.9 4.9 0 0 0 0-9.8zm0 8.1a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm5.1-8.3a1.1 1.1 0 1 0 0-2.3 1.1 1.1 0 0 0 0 2.3z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h2 class="footer-h">Explore</h2>
        <ul class="footer-links">
          {%- for item in navigation.items %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {%- endfor %}
        </ul>
      </div>
      <div>
        <h2 class="footer-h">Get in Touch</h2>
        <ul>
          <li><a href="tel:+12532546862" data-analytics="contact_click" data-analytics-method="phone" data-analytics-location="footer">{{ site.phone }}</a></li>
          <li><a href="mailto:{{ site.email }}" data-analytics="contact_click" data-analytics-method="email" data-analytics-location="footer">{{ site.email }}</a></li>
          <li><a href="{{ site.booking.vrboUrl }}" target="_blank" rel="noopener" data-analytics="vrbo_outbound_click" data-analytics-location="footer">Book on Vrbo</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-legal">
      <span>© {% year %} {{ site.name }}</span>
      <span>
        <a href="{{ site.legal.privacyUrl }}" target="_blank" rel="noopener">Privacy Policy</a> ·
        <a href="{{ site.legal.tosUrl }}" target="_blank" rel="noopener">Terms of Service</a>
      </span>
    </div>
  </div>
</footer>
